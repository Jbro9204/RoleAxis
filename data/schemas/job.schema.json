{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://roleaxis.local/schemas/job.schema.json",
  "title": "RoleAxis Job",
  "type": "object",
  "required": ["schemaVersion", "jobId", "fingerprint", "source", "sources", "company", "title", "status", "outcome", "match", "review", "matchFeedback", "metadata"],
  "additionalProperties": false,
  "$defs": {
    "sourceReceipt": {
      "type": "object",
      "required": ["sourceId", "name", "url", "externalId", "portalType", "importMethod", "retrievedAt", "lastSeenAt", "active"],
      "additionalProperties": false,
      "properties": {
        "sourceId": { "type": ["string", "null"] },
        "name": { "type": "string" },
        "url": { "type": "string", "format": "uri" },
        "externalId": { "type": "string" },
        "portalType": { "type": "string" },
        "importMethod": { "enum": ["manual", "public_feed"] },
        "retrievedAt": { "type": "string", "format": "date-time" },
        "lastSeenAt": { "type": "string", "format": "date-time" },
        "active": { "type": "boolean" }
      }
    }
  },
  "properties": {
    "schemaVersion": { "type": "string", "const": "1.1.0" },
    "jobId": { "type": "string" },
    "fingerprint": { "type": "string" },
    "source": { "$ref": "#/$defs/sourceReceipt" },
    "sources": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/sourceReceipt" } },
    "company": { "type": "string" },
    "title": { "type": "string" },
    "location": { "type": "string" },
    "remoteType": { "enum": ["remote", "hybrid", "onsite", "unknown"] },
    "salary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "minimum": { "type": ["number", "null"] },
        "maximum": { "type": ["number", "null"] },
        "currency": { "type": "string" },
        "period": { "enum": ["hour", "year", "month", "week", "unknown"] },
        "rawText": { "type": "string" }
      }
    },
    "description": { "type": "string" },
    "requirements": { "type": "array", "items": { "type": "string" } },
    "preferredQualifications": { "type": "array", "items": { "type": "string" } },
    "keywords": { "type": "array", "items": { "type": "string" } },
    "status": { "enum": ["found", "review_queue", "saved", "skipped", "applied", "interviewing", "closed"] },
    "outcome": { "enum": ["apply_now", "prepare_for_review", "ask_user", "save_for_later", "skip", "blocked"] },
    "match": {
      "type": "object",
      "required": ["score", "summary", "strengths", "concerns", "breakdown"],
      "additionalProperties": false,
      "properties": {
        "score": { "type": "number", "minimum": 0, "maximum": 100 },
        "summary": { "type": "string" },
        "strengths": { "type": "array", "items": { "type": "string" } },
        "concerns": { "type": "array", "items": { "type": "string" } },
        "breakdown": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["key", "label", "score", "maximum", "summary"],
            "additionalProperties": false,
            "properties": {
              "key": { "enum": ["title", "skills", "location", "compensation", "requirements"] },
              "label": { "type": "string" },
              "score": { "type": "number", "minimum": 0 },
              "maximum": { "type": "number", "minimum": 0 },
              "summary": { "type": "string" }
            }
          }
        }
      }
    },
    "review": {
      "type": "object",
      "required": ["decisionReason", "decidedAt"],
      "additionalProperties": false,
      "properties": {
        "decisionReason": { "type": ["string", "null"] },
        "decidedAt": { "type": ["string", "null"] }
      }
    },
    "matchFeedback": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": ["rating", "note", "updatedAt"],
          "additionalProperties": false,
          "properties": {
            "rating": { "enum": ["accurate", "too_high", "too_low"] },
            "note": { "type": "string" },
            "updatedAt": { "type": "string", "format": "date-time" }
          }
        }
      ]
    },
    "metadata": {
      "type": "object",
      "required": ["discoveredAt", "updatedAt", "expiresAt", "lastSeenAt", "sourceUpdatedAt"],
      "additionalProperties": false,
      "properties": {
        "discoveredAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": ["string", "null"] },
        "lastSeenAt": { "type": "string", "format": "date-time" },
        "sourceUpdatedAt": { "type": ["string", "null"] }
      }
    }
  }
}
