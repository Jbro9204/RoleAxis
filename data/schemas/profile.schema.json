{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://roleaxis.local/schemas/profile.schema.json",
  "title": "RoleAxis Profile",
  "type": "object",
  "required": ["schemaVersion", "profileId", "contact", "workHistory", "education", "skills", "truthRules", "metadata"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "type": "string", "const": "1.0.0" },
    "profileId": { "type": "string", "minLength": 1 },
    "contact": {
      "type": "object",
      "required": ["legalName", "email"],
      "additionalProperties": false,
      "properties": {
        "legalName": { "type": "string" },
        "preferredName": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "address": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "line1": { "type": "string" },
            "line2": { "type": "string" },
            "city": { "type": "string" },
            "state": { "type": "string" },
            "postalCode": { "type": "string" },
            "country": { "type": "string" }
          }
        }
      }
    },
    "workHistory": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["employer", "title", "startDate", "description"],
        "additionalProperties": false,
        "properties": {
          "employer": { "type": "string" },
          "title": { "type": "string" },
          "location": { "type": "string" },
          "startDate": { "type": "string" },
          "endDate": { "type": ["string", "null"] },
          "current": { "type": "boolean" },
          "description": { "type": "string" },
          "achievements": { "type": "array", "items": { "type": "string" } },
          "tools": { "type": "array", "items": { "type": "string" } },
          "industries": { "type": "array", "items": { "type": "string" } },
          "verified": { "type": "boolean" }
        }
      }
    },
    "education": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["institution", "credential"],
        "additionalProperties": false,
        "properties": {
          "institution": { "type": "string" },
          "credential": { "type": "string" },
          "fieldOfStudy": { "type": "string" },
          "startDate": { "type": "string" },
          "endDate": { "type": ["string", "null"] },
          "completed": { "type": "boolean" },
          "verified": { "type": "boolean" }
        }
      }
    },
    "certifications": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "issuer": { "type": "string" },
          "issuedDate": { "type": "string" },
          "expiresDate": { "type": ["string", "null"] },
          "credentialId": { "type": "string" },
          "verified": { "type": "boolean" }
        }
      }
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "source"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "category": { "type": "string" },
          "source": { "enum": ["resume", "intake", "manual", "document_review"] },
          "years": { "type": ["number", "null"], "minimum": 0 },
          "verified": { "type": "boolean" }
        }
      }
    },
    "links": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["label", "url"],
        "additionalProperties": false,
        "properties": {
          "label": { "type": "string" },
          "url": { "type": "string" },
          "includeByDefault": { "type": "boolean" }
        }
      }
    },
    "truthRules": {
      "type": "object",
      "required": ["neverClaim", "requiresConfirmation"],
      "additionalProperties": false,
      "properties": {
        "neverClaim": { "type": "array", "items": { "type": "string" } },
        "requiresConfirmation": { "type": "array", "items": { "type": "string" } },
        "notes": { "type": "string" }
      }
    },
    "metadata": {
      "type": "object",
      "required": ["createdAt", "updatedAt"],
      "additionalProperties": false,
      "properties": {
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" },
        "sourceResumeId": { "type": "string" }
      }
    }
  }
}

